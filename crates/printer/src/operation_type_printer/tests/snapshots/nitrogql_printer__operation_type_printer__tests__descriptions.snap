  id: Schema.__OperationOutput.ID;
}, {}> | Schema.__SelectionSet<Schema.__OperationOutput.Bot, {
  id: Schema.__OperationOutput.ID;
}, {}> | Schema.__SelectionSet<Schema.__OperationOutput.Post, {
  id: Schema.__OperationOutput.ID;
}, {}> | Schema.__SelectionSet<Schema.__OperationOutput.Tweet, {
